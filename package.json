{
  "name": "@shnwazdeveloper/shnwazdev",
  "version": "0.3.0",
  "description": "Safe real-time utility toolkit for shnwazdev projects.",
  "type": "module",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "secret:check": "node scripts/check-secrets.js",
    "safe:check": "npm run secret:check && npm test && npm run pack:check",
    "test": "node --test",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "npm run secret:check && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shnwazdeveloper/shnwazdev-package.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "keywords": [
    "shnwazdev",
    "github-packages",
    "utilities",
    "realtime",
    "polling",
    "events",
    "privacy",
    "redaction",
    "security"
  ],
  "author": "shnwazdeveloper",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/shnwazdeveloper/shnwazdev-package/issues"
  },
  "homepage": "https://github.com/shnwazdeveloper/shnwazdev-package#readme"
}
